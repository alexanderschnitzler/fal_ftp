{
	"name": "adgrafik/fal-ftp",
	"description": "Provides a FTP and FTP-SSL driver for the TYPO3 File Abstraction Layer (FAL) to manage files via filemanager (filelist).",
	"license": [
		"GPL-2.0-or-later"
	],
	"type": "typo3-cms-extension",
	"require": {
		"php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
		"ext-ftp": "*",
		"psr/http-message": "*",
		"typo3/cms-backend": "~13.4.0 || ~14.3.0",
		"typo3/cms-core": "~13.4.0 || ~14.3.0"
	},
	"require-dev": {
		"friendsofphp/php-cs-fixer": "^3.95",
		"overtrue/phplint": "^9.7",
		"phpstan/phpstan": "^2.2",
		"ssch/typo3-rector": "^3.14"
	},
	"autoload": {
		"psr-4": {
			"AdGrafik\\FalFtp\\": "Classes"
		}
	},
	"config": {
		"allow-plugins": {
			"typo3/class-alias-loader": false,
			"typo3/cms-composer-installers": false
		},
		"platform": {
			"php": "8.2.99"
		},
		"sort-packages": true
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "fal_ftp"
		}
	}
}
