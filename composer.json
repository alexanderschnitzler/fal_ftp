{
	"name": "adgrafik/fal-ftp",
	"description": "",
	"type": "typo3-cms-extension",
	"require": {
		"php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
		"ext-ftp": "*",
		"psr/http-message": "*",
		"typo3/cms-backend": "~13.4.0",
		"typo3/cms-core": "~13.4.0"
	},
	"require-dev": {
		"friendsofphp/php-cs-fixer": "^3.95",
		"phpstan/phpstan": "^2.2"
	},
	"autoload": {
		"psr-4": {
			"AdGrafik\\FalFtp\\": "Classes"
		}
	},
	"config": {
		"allow-plugins": {
			"typo3/class-alias-loader": false,
			"typo3/cms-composer-installers": false
		},
		"platform": {
			"php": "8.2.99"
		},
		"sort-packages": true
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "fal_ftp"
		}
	}
}
